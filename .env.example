# ========================================
# Конфигурация tg_userbot
# Скопируй этот файл в .env и заполни значения
# ========================================

# Telegram API credentials
# Получить на https://my.telegram.org -> API development tools
API_ID=12345678
API_HASH=your_api_hash_here

# Google Gemini API key
# Получить на https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Модель Gemini для генерации ответов
GEMINI_MODEL=gemini-2.5-flash

# Резервная модель Gemini на случай временной перегрузки основной
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Параметры повторных попыток при временных ошибках Gemini
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.0
GEMINI_RETRY_JITTER_SECONDS=0.3

# Строковая Telethon-сессия
# Секрет. Не публиковать и не логировать.
SESSION_STRING=your_telethon_session_string_here

# Общий proxy URL для Telegram и Gemini API (необязательно)
# Пример: http://user:pass@127.0.0.1:8080
PROXY_URL=

# Путь к файлу базы данных SQLite для истории диалогов
DB_PATH=data/history.db

# Разрешённые Telegram user_id через запятую (без пробелов)
# Узнать user_id: написать боту @userinfobot
WHITELIST_USER_IDS=123456789,987654321

# Путь к файлу со списком тем для разговора
TOPICS_PATH=data/topics.md

# Путь к markdown-файлу с триггерными подсказками для ответов
REPLY_RULES_PATH=data/reply_rules.md

# Директория с .md файлами промтов
PROMPTS_DIR=ai/prompts

# PROXY
PROXY_URL="http://[login]:[pass]@[host]:[port]"

# Планировщик разговоров
# Включить/выключить режим расписания (true/false)
# При false бот только слушает и отвечает пользователям из whitelist
SCHEDULER_ENABLED=true

# Время тишины в минутах, после которого бот сам заводит разговор
# Работает только если SCHEDULER_ENABLED=true
SILENCE_TIMEOUT_MINUTES=60

# Длительность одной сессии разговора в минутах
# За 2 минут до конца агент получает подсказку плавно завершить диалог
SESSION_DURATION_MINUTES=30

# UTC-интервал режима не беспокоить в формате HH-HH
# В этот период бот не отвечает и не запускает новые темы
# Пример: 23-7
DND_HOURS_UTC=

# Telegram chat_id группы для фильтрации входящих сообщений
# Узнать: переслать сообщение из группы боту @userinfobot или включить DEBUG логи
GROUP_CHAT_ID=

# Строковый target группы для исходящих сообщений по расписанию
# Предпочтительно указать @username, публичную ссылку https://t.me/... или invite link
# Для каналов и супергрупп одного GROUP_CHAT_ID обычно недостаточно
GROUP_TARGET=
