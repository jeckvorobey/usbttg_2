# Секреты swarm userbot.
# Скопируй в .env и подставь реальные значения.

# Telegram API credentials
API_ID=12345678
API_HASH=your_api_hash_here

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Строковые Telethon-сессии для каждого бота из settings.toml
# Названия должны совпадать с session_env в [[swarm.bots]]
SESSION_STRING_ANNA=your_telethon_session_string_for_anna
SESSION_STRING_MIKE=your_telethon_session_string_for_mike

# Общий proxy URL для Telegram и Gemini API (необязательно)
# Пример: http://user:pass@127.0.0.1:8080
PROXY_URL=

# Путь к TOML-конфигурации swarm
SETTINGS_PATH=config/settings.toml
